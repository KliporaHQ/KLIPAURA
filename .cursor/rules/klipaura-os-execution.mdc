`klip-trader/signal_emitter.py`:
```python
from upstash_redis import Redis
import json
from datetime import datetime, timezone

def emit_market_sentiment(score: float, symbol: str = "BTCUSDT"):
    """score: -1.0 (bearish) to 1.0 (bullish). TTL 5 min."""
    Redis.from_env().set("klip:market:sentiment", json.dumps({
        "score": score, "symbol": symbol,
        "ts": datetime.now(timezone.utc).isoformat()
    }), ex=300)
```

`klip-selector/scorer.py` — sentiment weighting:
```python
LUXURY = ["beauty", "tech", "gadget", "premium"]
VALUE  = ["home", "kitchen", "budget", "essentials"]

def score(product: dict) -> float:
    base = product["commission_rate"] * 0.6 + product.get("trend_score", 0.5) * 0.4
    try:
        sentiment = json.loads(Redis.from_env().get("klip:market:sentiment") or "{}")
        s = float(sentiment.get("score", 0.0))
        if s > 0.5 and product.get("category","") in LUXURY: base *= 1.3
        elif s < -0.5 and product.get("category","") in VALUE: base *= 1.3
    except Exception:
        pass
    return base
```

Spawn gate in `revenue_tracker.py`:
```python
def check_spawn_milestone():
    from upstash_redis import Redis
    entries = [json.loads(l) for l in Path("revenue.jsonl").read_text().splitlines() if l]
    by_avatar = {}
    for e in entries:
        by_avatar.setdefault(e["avatar_id"], 0)
        by_avatar[e["avatar_id"]] += e.get("commission_rate", 0) / 100 * 50  # est. sale value
    for avatar, total in by_avatar.items():
        if total >= 1000:
            Redis.from_env().lpush("klip:spawn:ready", json.dumps({
                "avatar_id": avatar, "total_pnl": total, "ts": _now()
            }))
```

