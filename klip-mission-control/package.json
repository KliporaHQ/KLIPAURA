{
  "name": "klip-mission-control",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:next": "powershell -ExecutionPolicy Bypass -File ./scripts/run-next-dev.ps1",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 -p 8080",
    "lint": "next lint",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "dev:clean": "npm run clean && next dev",
    "dev:api": "powershell -ExecutionPolicy Bypass -File ./scripts/run-api-local.ps1",
    "dev:avatar-worker": "powershell -ExecutionPolicy Bypass -File ./scripts/run-avatar-worker.ps1",
    "dev:stack": "concurrently -k -n api,next -c cyan,magenta \"npm run dev:api\" \"npm run dev:next\"",
    "dev:full": "concurrently -k -n api,next,avatar -c cyan,magenta,green \"npm run dev:api\" \"npm run dev:next\" \"npm run dev:avatar-worker\""
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "framer-motion": "^11.18.2",
    "jose": "^5.10.0",
    "lucide-react": "^0.312.0",
    "next": "14.1.0",
    "playwright": "^1.49.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
