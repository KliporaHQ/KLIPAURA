# KLIP-AVATAR Core V1 - Copy to .env and fill in your keys
# Required for production activation
GROQ_API_KEY=gsk_...
ELEVENLABS_API_KEY=...
USE_REDIS=false
USE_GETLATE=false
ACTIVE_AVATAR_ID=default
WAVESPEED_API_KEY=...
FFMPEG_PATH=ffmpeg
OUTPUT_DIR=output
DEBUG=true
PORT=8000

# UGC URL pipeline — affiliate split / product visibility (optional; ugc_pipeline also sets sane defaults)
# AFFILIATE_SPLIT_TOP_RATIO=0.70
# SPLIT_TOP_RATIO=0.70
# PRODUCT_FIRST_N_SECONDS=3
# PRODUCT_MIN_VISIBLE_SECONDS=6
# CAPTION_BOTTOM_MARGIN=180