# Copy to `.env` at repo root (never commit `.env`). Sync with `klip-avatar/core_v1/.env` when editing pipeline keys.

# --- Redis (one of) ---
# Local:
# REDIS_URL=redis://localhost:6379/0
# Upstash REST:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare R2 (optional; public video URL for Zernio) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://your-bucket.r2.dev

# --- HITL / API ---
# PORT=8080
# JOBS_DIR=E:/KLIPAURA/jobs
# Production: list UI origins (do not rely on default localhost-only CORS).
# CORS_ALLOW_ORIGINS=https://app.klipaura.com,https://mc.klipaura.com
# Explicit wildcard (not recommended in prod): CORS_ALLOW_ORIGINS=*
# AFFILIATE_PROGRAMS_PATH=  (optional override; default config/affiliate_programs.json)
# OPS_API_KEY=long-random-string
# (Mission Control: POST /api/selector/run and POST /api/market/sentiment require header X-Ops-Key)

# --- Autopilot ---
# AUTOPILOT_MODE=0
# MAX_DAILY_VIDEOS=10
# SELECTOR_LIMIT=5
# SELECTOR_AVATAR_ID=theanikaglow
# PRODUCTS_CSV=products.csv
# SELECTOR_UAE_MORNING_HOUR=6
# SELECTOR_UAE_EVENING_HOUR=19
# GUARDIAN_INTERVAL_MIN=30

# --- Spawn milestone (optional Telegram) ---
# SPAWN_MILESTONE_USD=1000
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Public marketing site (matches Flask `PUBLIC_SITE_URL` / klipaura.com)
# PUBLIC_SITE_URL=https://klipaura.com

# On the Flask site (anika-glow-affiliate), set KLIP_STUDIO_URL to your deployed HITL API
# so the footer shows “Creator pipeline”. Not required for local dev.

# --- WaveSpeed (optional tuning; defaults are safe) ---
# WAVESPEED_HTTP_TIMEOUT_SEC=120
# WAVESPEED_I2V_MAX_RETRIES=2
# WAVESPEED_LIPSYNC_MAX_RETRIES=2
# Worker: manifest heartbeat interval sec (default 18) and ugc_pipeline max wall time (default 7200)
# KLIP_WORKER_MANIFEST_HB_SEC=18
# KLIP_PIPELINE_SUBPROCESS_TIMEOUT_SEC=7200

# --- Pipeline (see core_v1 .env for full list: WaveSpeed, Groq, ElevenLabs, etc.) ---
# UGC_PRODUCT_URL=
# ACTIVE_AVATAR_ID=theanikaglow

# --- Funnel pages (optional; worker + POST /api/jobs/{id}/generate-funnel) ---
# FUNNEL_PUBLIC_BASE_URL=https://cdn.klipaura.com
# When R2 not configured, HTML is written under JOBS_DIR/<job_id>/funnel_<slug>.html and funnel_url may be local://...

# --- Mission Control Next.js (build-time; see docs/MISSION_CONTROL.md) ---
# Browser → API when UI and API differ (e.g. app.klipaura.com → api.klipaura.com):
# NEXT_PUBLIC_API_BASE_URL=https://api.klipaura.com
# NEXT_PUBLIC_API_URL=  (legacy fallback for same purpose)
# Server-side rewrites (next dev / Docker): loopback only, not public Railway hostnames
# MC_INTERNAL_API_URL=http://127.0.0.1:8000
# MC_INTERNAL_HITL_URL=http://127.0.0.1:8080
