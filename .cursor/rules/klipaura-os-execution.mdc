## PHASE 1 — CLOSE THE REVENUE LOOP

### 1A — Job Filesystem + R2 Upload

`infrastructure/job_state.py`:
```python
import json, os
from pathlib import Path

JOBS_DIR = Path(os.getenv("JOBS_DIR", "jobs"))

def create_manifest(job_id: str, payload: dict) -> None:
    d = JOBS_DIR / job_id
    d.mkdir(parents=True, exist_ok=True)
    (d / "manifest.json").write_text(json.dumps({
        "job_id": job_id, "status": "QUEUED",
        "created_at": _now(), "payload": payload,
        "retry_count": 0, "r2_url": None
    }, indent=2))

def update_manifest(job_id: str, **kwargs) -> None:
    path = JOBS_DIR / job_id / "manifest.json"
    data = json.loads(path.read_text())
    data.update(kwargs)
    data["updated_at"] = _now()
    path.write_text(json.dumps(data, indent=2))

def read_manifest(job_id: str) -> dict:
    return json.loads((JOBS_DIR / job_id / "manifest.json").read_text())
```

