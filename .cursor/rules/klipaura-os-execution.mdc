## PHASE 2 — QUEUE WORKER

`klip-avatar/worker.py`:
```python
from upstash_redis import Redis
from infrastructure.job_state import create_manifest, update_manifest
import subprocess, json, os, sys

MAX_RETRIES = 3

def main():
    r = Redis.from_env()
    print("[WORKER] Online — polling klip:jobs:pending", flush=True)
    while True:
        raw = r.blpop(["klip:jobs:pending"], timeout=10)
        if not raw:
            continue
        job = json.loads(raw[1])
        job_id = job["job_id"]
        retry = job.get("retry_count", 0)
        create_manifest(job_id, job)
        env = {**os.environ,
               "UGC_PRODUCT_URL": job["product_url"],
               "ACTIVE_AVATAR_ID": job.get("avatar_id", "theanikaglow"),
               "JOB_ID": job_id,
               "KLIP_PIPELINE_RUN": "1"}
        result = subprocess.run(
            [sys.executable, "-m", "pipeline.ugc_pipeline"],
            cwd="klip-avatar/core_v1", env=env
        )
        if result.returncode != 0 and retry < MAX_RETRIES:
            job["retry_count"] = retry + 1
            r.lpush("klip:jobs:pending", json.dumps(job))
            update_manifest(job_id, status="RETRYING", retry_count=retry+1)
        elif result.returncode != 0:
            r.lpush("klip:dlq", json.dumps(job))
            update_manifest(job_id, status="DEAD_LETTER")

if __name__ == "__main__":
    main()
```

**Validation gate:** `POST /api/jobs {"product_url": "..."}` → 5 min later video appears in HITL with no terminal interaction.

